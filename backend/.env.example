#========================================
# SERVER CONFIGURATION
#========================================
PORT=4001

#========================================
# DATABASE
#========================================
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/livya?retryWrites=true&w=majority

#========================================
# OPENAI API
#========================================
OPENAI_API_KEY=sk-proj-...

#========================================
# RUNWAYML VIDEO GENERATION
#========================================
RUNWAYML_API_SECRET=key_...

#========================================
# AWS S3 CONFIGURATION
#========================================
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET_NAME=your-s3-bucket-name

# Optional: Custom CDN or S3 base URL for image/video serving
# Defaults to: https://<S3_BUCKET_NAME>.s3.<AWS_REGION>.amazonaws.com
# S3_BASE_URL=https://your-cdn-domain.com

#========================================
# AUTHENTICATION
#========================================
JWT_SECRET=your-secret-key-for-jwt-signing
GOOGLE_CLIENT_ID=xxx-xxx-xxx.apps.googleusercontent.com

#========================================
# REDIS (MESSAGE QUEUE) - OPTIONAL
#========================================
# Required for BullMQ image processing queue
# Use REDIS_URL if connecting to remote Redis
# REDIS_URL=redis://username:password@host:port

# Or use REDIS_HOST + REDIS_PORT for local development
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
